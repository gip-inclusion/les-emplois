[
{
  "model": "siae_evaluations.calendar",
  "pk": 1,
  "fields": {
    "name": "contrôle pour la période du 20/08/2025 au 20/10/2025",
    "adversarial_stage_start": "2026-01-01",
    "html": "<p>\r\n    Retrouvez ci-dessous toutes les dates concernant la campagne de contrôle a posteriori sur les auto-prescriptions du 01/01/2022 au 31/12/2022 (ou du 01/10/2022 au 31/12/2022 pour les DDETS ayant déjà réalisé la campagne optionnelle du 01/01/2022 au 31/09/2022).\r\n</p>\r\n\r\n<div class=\"table-responsive mt-3 mt-md-4\">\r\n    <table class=\"table table-hover\">\r\n        <caption class=\"visually-hidden\">Liste des campagnes de contrôle a posteriori</caption>\r\n        <thead>\r\n            <tr>\r\n                <th scope=\"col\"></th>\r\n                <th scope=\"col\">Dates</th>\r\n                <th scope=\"col\">Acteurs</th>\r\n                <th scope=\"col\">Actions attendues</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            <tr>\r\n                <th scope=\"row\">\r\n                    <span class=\"d-block\">Phase 1</span>\r\n                    <span class=\"fw-bold\">Échantillonnage</span>\r\n                </th>\r\n                <td>\r\n                    Du 15 mai 2023\r\n                    <br>\r\n                    au 11 juin 2023\r\n                </td>\r\n                <td>DDETS</td>\r\n                <td>\r\n                    <ul>\r\n                        <li>Sélection du taux de SIAE à contrôler sur le département.</li>\r\n                    </ul>\r\n                </td>\r\n            </tr>\r\n            <tr>\r\n                <th scope=\"row\">\r\n                    <span class=\"d-block\">Phase 2 – phase amiable</span>\r\n                    <span class=\"fw-bold\">Transmission des pièces justificatives</span>\r\n                </th>\r\n                <td>\r\n                    Du 12 juin 2023\r\n                    <br>\r\n                    au 23 juillet 2023\r\n                </td>\r\n                <td>SIAE</td>\r\n                <td>\r\n                    <ul>\r\n                        <li>Sélection des critères servant à justifier chaque auto-prescription sélectionnée</li>\r\n                        <li>Transmission des justificatifs.</li>\r\n                    </ul>\r\n                </td>\r\n            </tr>\r\n            <tr>\r\n                <th scope=\"row\">\r\n                    <span class=\"d-block\">Phase 2 – phase amiable</span>\r\n                    <span class=\"fw-bold\">Contrôle des pièces justificatives</span>\r\n                </th>\r\n                <td>\r\n                    Du 12 juin 2023\r\n                    <br>\r\n                    au 31 août 2023\r\n                </td>\r\n                <td>DDETS</td>\r\n                <td>\r\n                    <ul>\r\n                        <li>Contrôle des justificatifs.</li>\r\n                    </ul>\r\n                </td>\r\n            </tr>\r\n            <tr>\r\n                <td colspan=\"4\" class=\"fst-italic py-5\">\r\n                    Les phase 3 et 4 ne concernent que les SIAE ayant reçu un résultat négatif à l’issue de la phase amiable.\r\n                </td>\r\n            </tr>\r\n            <tr>\r\n                <th scope=\"row\">\r\n                    <span class=\"d-block\">Phase 3 – phase contradictoire</span>\r\n                    <span class=\"fw-bold\">Transmission des pièces justificatives</span>\r\n                </th>\r\n                <td>\r\n                    Du 1er septembre 2023\r\n                    <br>\r\n                    au 13 octobre 2023\r\n                </td>\r\n                <td>SIAE</td>\r\n                <td>\r\n                    <ul>\r\n                        <li>Transmission des résultats de la phase 2.</li>\r\n                        <li>Transmission des nouveaux justificatifs.</li>\r\n                    </ul>\r\n                </td>\r\n            </tr>\r\n            <tr>\r\n                <th scope=\"row\">\r\n                    <span class=\"d-block\">Phase 3 – phase contradictoire</span>\r\n                    <span class=\"fw-bold\">Contrôle des pièces justificatives</span>\r\n                </th>\r\n                <td>\r\n                    Du 1er septembre 2023\r\n                    <br>\r\n                    au 27 octobre 2023\r\n                </td>\r\n                <td>DDETS</td>\r\n                <td>\r\n                    <ul>\r\n                        <li>Contrôle des nouveaux justificatifs.</li>\r\n                    </ul>\r\n                </td>\r\n            </tr>\r\n            <tr>\r\n                <th scope=\"row\">\r\n                    <span class=\"d-block\">Phase 4</span>\r\n                    <span class=\"fw-bold\">Déclaration des sanctions</span>\r\n                </th>\r\n                <td>\r\n                    Du 28 octobre 2023\r\n                    <br>\r\n                    au 28 mars 2024\r\n                </td>\r\n                <td>DDETS</td>\r\n                <td>\r\n                    <ul>\r\n                        <li>Transmission des résultats définitifs.</li>\r\n                        <li>Notification à chaque SIAE concernée en précisant :</li>\r\n                        <ul>\r\n                            <li>Le motif du résultat négatif.</li>\r\n                            <li>Les sanctions à appliquer.</li>\r\n                        </ul>\r\n                    </ul>\r\n                </td>\r\n            </tr>\r\n        </tbody>\r\n    </table>\r\n</div>"
  }
},
