# name: TestListView.test_view
  '''
  <table class="table table-hover table-sortable">
      <caption class="visually-hidden">
          Liste des demandeurs d'emploi accompagnés
      </caption>
      <thead>
          <tr>
              <th aria-sort="ascending" scope="col">
                  <button data-emplois-setter-target="#id_order" data-emplois-setter-value="-full_name" type="button">
                      Nom Prénom
                  </button>
              </th>
              <th class="text-end w-50px" scope="col">
                  <span class="visually-hidden">
                      Actions possibles sur les demandeurs d'emploi accompagnés
                  </span>
              </th>
          </tr>
      </thead>
      <tbody>
          <tr>
              <td>
                  <a class="btn-link" data-matomo-action="clic" data-matomo-category="recommendations" data-matomo-event="true" data-matomo-option="consulter_le_profil" href="/recommendations/[PUBLIC_ID]/profile?back_url=/recommendations/list">
                      DOE John
                  </a>
              </td>
              <td class="text-end w-50px align-middle">
                  <a class="btn btn-sm btn-link btn-ico-only" data-bs-title="Voir la fiche de DOE John" data-bs-toggle="tooltip" href="/recommendations/[PUBLIC_ID]/profile?back_url=/recommendations/list">
                      <i aria-label="Voir la fiche de DOE John" class="ri-arrow-drop-right-line fs-lg">
                      </i>
                  </a>
              </td>
          </tr>
      </tbody>
  </table>
  
  '''
