    '\tADDED {"source": "dora", "id": "dora--cc4e1fbc-533b-46e2-8b33-bc31c33c9ffd", "nom": "PLATEFORME DE L\'INCLUSION", "date_maj": "2024-02-02", "description": "La Plateforme de l’inclusion est un Groupement d’Intérêt Public créé par arrêté en avril 2022. Elle développe de nouveaux services publics pour faciliter la vie des personnes en insertion et de celles et ceux qui les accompagnent.", "lien_source": "https://dora.inclusion.gouv.fr/structures/plateforme-de-linclu", "siret": "13003013300016", "commune": "Paris", "code_postal": "75010", "code_insee": "75056", "adresse": "6 Boulevard Saint-Denis", "complement_adresse": null, "longitude": 2.35511, "latitude": 48.869364, "telephone": null, "courriel": null, "site_web": "https://inclusion.gouv.fr/", "horaires_accueil": null, "accessibilite_lieu": null, "reseaux_porteurs": null}',
